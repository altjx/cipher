{
  "name": "android-messages",
  "version": "1.0.0",
  "description": "Desktop client for Android Messages",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && bash scripts/patch-electron-name.sh && open -W \"node_modules/electron/dist/Android Messages.app\" --args \"$PWD/dist/main.js\"",
    "build": "tsc && electron-builder && cp -R \"dist/mac-arm64/Android Messages.app\" /Applications/",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.android-messages",
    "productName": "Android Messages",
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/backend",
        "to": "backend"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "tree-kill": "^1.2.2",
    "ws": "^8.19.0"
  }
}
