#!/bin/bash

# Git commit-msg hook for enforcing Conventional Commits.
# Install with: ./scripts/install-git-hooks.sh

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

if echo "$COMMIT_MSG" | grep -q "^Merge "; then
    exit 0
fi

if echo "$COMMIT_MSG" | grep -q "^Revert "; then
    exit 0
fi

VALID_TYPES="feat|fix|perf|docs|chore|refactor|style|test|ci"
PATTERN="^($VALID_TYPES)(\(.+\))?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}                  COMMIT MESSAGE REJECTED                    ${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Your commit message:${NC}"
    echo -e "${BLUE}$COMMIT_MSG${NC}"
    echo ""
    echo -e "${RED}✗ This commit message does not follow Conventional Commits${NC}"
    echo ""
    echo -e "${YELLOW}Required format:${NC}"
    echo "  type(scope): subject"
    echo ""
    echo -e "${YELLOW}Valid types:${NC}"
    echo "  feat     - New features (MINOR version bump)"
    echo "  fix      - Bug fixes (PATCH version bump)"
    echo "  perf     - Performance improvements (PATCH version bump)"
    echo "  docs     - Documentation changes"
    echo "  chore    - Maintenance tasks"
    echo "  refactor - Code refactoring"
    echo "  style    - Code style changes"
    echo "  test     - Test updates"
    echo "  ci       - CI/CD changes"
    echo ""
    echo -e "${YELLOW}Examples:${NC}"
    echo "  feat(messages): add drag-and-drop attachments"
    echo "  fix(electron): restore unread dock badge updates"
    echo "  docs(readme): add quick start instructions"
    echo ""
    echo -e "${YELLOW}For more information:${NC}"
    echo "  See docs/COMMIT_CONVENTIONS.md"
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
fi

SUBJECT_LINE=$(echo "$COMMIT_MSG" | head -n 1)
SUBJECT_LENGTH=${#SUBJECT_LINE}

if [ "$SUBJECT_LENGTH" -gt 100 ]; then
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}                    COMMIT MESSAGE WARNING                    ${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}⚠ Warning: Subject is $SUBJECT_LENGTH characters long${NC}"
    echo -e "  Recommended maximum: 72 characters"
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
fi

echo -e "${GREEN}✓ Commit message follows Conventional Commits format${NC}"
exit 0
